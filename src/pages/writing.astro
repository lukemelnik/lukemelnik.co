---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ContentList from "../components/content-search";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection(
  "blog",
  ({ data }: { data: CollectionEntry<"blog">["data"] }) =>
    import.meta.env.PROD ? data.draft !== true : true,
);
---

<BaseLayout
  title="Writing"
  description="Essays and notes by Luke Melnik."
>
  <main class="mx-auto w-full max-w-2xl pt-14 pb-24">
    <SiteHeader />

    <h1
      class="text-muted-foreground mb-6 font-mono text-xs font-medium tracking-wider uppercase"
    >
      Writing
    </h1>

    <ContentList client:load collection={posts} type="blog" />
  </main>
</BaseLayout>
