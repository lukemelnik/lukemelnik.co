---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const projects = (
  await getCollection(
    "projects",
    ({ data }: { data: CollectionEntry<"projects">["data"] }) =>
      import.meta.env.PROD ? data.draft !== true : true,
  )
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const statusLabel: Record<string, string> = {
  shipped: "Shipped",
  wip: "WIP",
  archived: "Archived",
};
---

<BaseLayout
  title="Projects"
  description="Projects by Luke Melnik."
>
  <main class="mx-auto w-full max-w-2xl pt-14 pb-24">
    <SiteHeader />

    <h1
      class="text-muted-foreground mb-6 font-mono text-xs font-medium tracking-wider uppercase"
    >
      Projects
    </h1>

    <div class="flex flex-col">
      {
        projects.map((project) => {
          const firstTech = project.data.technologies?.[0];
          const status = project.data.status
            ? statusLabel[project.data.status]
            : null;
          const meta = [firstTech, status].filter(Boolean).join(" · ");
          return (
            <div class="border-border flex items-baseline justify-between gap-4 border-b py-3.5">
              <div class="min-w-0 flex-1">
                <a
                  href={`/projects/${project.id}`}
                  class="hover:text-accent text-[15px] font-medium transition-colors"
                >
                  {project.data.title}
                </a>
                {project.data.description && (
                  <p class="text-muted-foreground mt-1 text-sm leading-snug">
                    {project.data.description}
                  </p>
                )}
              </div>
              {meta && (
                <span class="text-muted-foreground shrink-0 font-mono text-xs">
                  {meta}
                </span>
              )}
            </div>
          );
        })
      }
    </div>
  </main>
</BaseLayout>
