---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import RecipeSearch from "../components/content-search";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const recipes = await getCollection(
  "recipes",
  ({ data }: { data: CollectionEntry<"recipes">["data"] }) =>
    import.meta.env.PROD ? data.draft !== true : true,
);
---

<BaseLayout
  title="Recipes"
  description="Recipes Luke loves to make. Family recipes marked with F."
>
  <main class="mx-auto w-full max-w-2xl pt-14 pb-24">
    <SiteHeader />

    <h1
      class="text-muted-foreground mb-4 font-mono text-xs font-medium tracking-wider uppercase"
    >
      Recipes
    </h1>

    <p class="text-foreground/85 mb-6 text-[15px]">
      Things I love to make. Family recipes marked with <sup class="text-[10px]"
        >F</sup
      >.
    </p>

    <RecipeSearch client:load collection={recipes} />
  </main>
</BaseLayout>
