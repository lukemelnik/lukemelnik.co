---
import SquareIcon from "./SquareIcon.astro";

interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;
---

<div class="mb-10 inline-flex items-center gap-2.5">
  <span class="animate-spin-slow inline-flex">
    <SquareIcon size={16} />
  </span>
  {
    home ? (
      <span class="font-mono text-sm font-bold">Luke Melnik</span>
    ) : (
      <a
        href="/"
        class="hover:text-accent font-mono text-sm font-bold transition-colors"
      >
        Luke Melnik
      </a>
    )
  }
</div>
