---
import BaseLayout from "./BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import Ingredients from "../components/ingredients";
import { ArrowUpLeft } from "lucide-react";

interface Props {
  recipe: CollectionEntry<"recipes">;
}

const { recipe } = Astro.props;
const { title, description, publishDate, image, ingredients, familyRecipe, bread } =
  recipe.data;
---

<BaseLayout title={title} description={description} image={image?.src}>
  <article class="mx-auto w-full max-w-2xl pt-14 pb-24">
    <a
      href="/recipes"
      class="text-muted-foreground hover:text-accent group inline-flex items-center gap-1.5 font-mono text-sm transition-colors"
    >
      <ArrowUpLeft
        size={14}
        className="transition-transform duration-300 group-hover:-translate-x-0.5 group-hover:-translate-y-0.5"
      />
      Recipes
    </a>

    <header class="mt-8 mb-6">
      <h1 class="text-foreground text-3xl font-bold">
        {title}{familyRecipe && <sup class="ml-1 text-xs">F</sup>}
      </h1>
      {
        description && (
          <p class="text-foreground/85 mt-3 text-base leading-relaxed">
            {description}
          </p>
        )
      }
    </header>

    <div class="border-border border-b"></div>

    <section class="mt-8">
      <h2 class="text-foreground mb-4 text-xl font-bold">Ingredients</h2>
      <Ingredients ingredients={ingredients} bread={bread} client:load />
    </section>

    <div class="border-border my-8 border-b"></div>

    <div
      class="prose prose-a:no-underline prose-a:hover:underline prose-strong:text-foreground prose-strong:font-bold prose-headings:mb-3 prose-headings:mt-8 prose-a:text-accent prose-a:font-bold prose-p:text-base prose-blockquote:text-foreground prose-pre:border-1 prose-pre:border-foreground prose-headings:text-foreground prose-code:text-accent prose-code:font-normal prose-code:before:content-none prose-code:after:content-none prose-li:m-0 prose-p:my-2 text-foreground/85 marker:text-accent"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
