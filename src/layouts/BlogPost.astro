---
import BaseLayout from "./BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { ArrowLeft } from "lucide-react";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, publishDate, cover, tags } = post.data;
---

<BaseLayout title={title} description={description} image={cover}>
  <article
    class="prose-a:no-underline prose-a:hover:underline prose-strong:text-foreground prose-strong:font-bold prose-headings:mb-4 prose-a:text-accent prose-h1:text-4xl prose-a:font-bold prose-p:text-base prose prose-blockquote:text-foreground prose-pre:border-1 prose-pre:border-foreground lg:prose-lg text-foreground/80 prose-headings:text-foreground mx-auto max-w-2xl py-12 marker:text-accent"
  >
    <a href="/blog" class="text-sm font-extralight"><span class="items-center flex gap group"><ArrowLeft size={15} className="group-hover:-translate-x-1 transition-all duration-300"/>  Back to blog</span></a>
    <h1 class="">{title}</h1>
    <div>
      <div class="flex flex-col sm:flex-row text-sm sm:items-center sm:gap-6">
        <time datetime={publishDate.toISOString()} class="">
          {
            publishDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        <div>
          {
            tags?.map((tag) => (
              <span>
                <a class="fancy-link" href={`/blog/?search=${tag}`}>
                  #{tag}
                </a>
              </span>
            ))
          }
        </div>
      </div>
      <slot />
    </div>
  </article>
</BaseLayout>
