---
import BaseLayout from "./BaseLayout.astro";
import { type CollectionEntry } from "astro:content";
import { ArrowUpLeft } from "lucide-react";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, publishDate, cover, tags } = post.data;
---

<BaseLayout title={title} description={description} image={cover}>
  <article class="mx-auto w-full max-w-2xl pt-14 pb-24">
    <a
      href="/writing"
      class="text-muted-foreground hover:text-accent group inline-flex items-center gap-1.5 font-mono text-sm transition-colors"
    >
      <ArrowUpLeft
        size={14}
        className="transition-transform duration-300 group-hover:-translate-x-0.5 group-hover:-translate-y-0.5"
      />
      Writing
    </a>

    <header class="mt-8 mb-8">
      <h1 class="text-foreground mb-3 text-3xl font-bold">{title}</h1>
      <div
        class="text-muted-foreground flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs"
      >
        <time datetime={publishDate.toISOString()}>
          {
            publishDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        {
          tags && tags.length > 0 && (
            <span class="text-muted-foreground/60">·</span>
          )
        }
        {
          tags?.map((tag) => (
            <span class="text-muted-foreground">{tag}</span>
          ))
        }
      </div>
    </header>

    <div
      class="prose lg:prose-lg prose-a:no-underline prose-a:hover:underline prose-strong:text-foreground prose-strong:font-bold prose-headings:mb-4 prose-a:text-accent prose-a:font-bold prose-p:text-base prose-blockquote:text-foreground prose-pre:border-1 prose-pre:border-foreground prose-headings:text-foreground text-foreground/85 marker:text-accent"
    >
      <slot />
    </div>
  </article>
</BaseLayout>
